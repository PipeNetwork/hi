/target

# Coverage artifacts (re-derived from test runs).
/coverage.lcov
/coverage_html/

# Auto-generated, re-derived every session — local working state, not curated docs.
# Track it (git add -f .hi/memory.md) if you'd rather share project memory with the team.
/.hi/
# Nested workspace runtimes may place checkpoint/transaction state below a
# crate root; keep a trackable `.hi/config.toml` possible while ignoring state.
/crates/*/.hi/state/
/crates/*/.hi/transactions/
/crates/*/.hi/history

# Test artifacts: temp files created by hi-agent tests that leaked into the
# workspace. visible_temp_file uses hi-test-* names in the workspace root (not
# gitignored, so the workspace snapshot can see them for change detection).
# These are cleaned up by the tests; this pattern catches any that leak.
.hi-verify-*

# hi-agent test scratch dir. Gitignored on purpose: the workspace snapshot
# respects gitignore, so scratch files created by parallel tests stay out of
# other tests' changed-files diffs (see tests/common.rs temp_file).
hi-test-scratch/

# Local Python virtualenv (created by tooling, not source).
/.venv/

# Downloaded model weights / artifacts (large, machine-local).
/models/
