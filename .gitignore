/target

# Coverage artifacts (re-derived from test runs).
/coverage.lcov
/coverage_html/

# Auto-generated, re-derived every session — local working state, not curated docs.
# Track it (git add -f .hi/memory.md) if you'd rather share project memory with the team.
/.hi/

# Test artifacts: temp files created by hi-agent tests that leaked into the
# workspace. The current temp_file helper uses hi-test-* names (not gitignored,
# so the workspace snapshot can see them for change detection). These are
# cleaned up by the tests; this pattern catches any that leak from older tests.
.hi-verify-*

# Local Python virtualenv (created by tooling, not source).
/.venv/

# Downloaded model weights / artifacts (large, machine-local).
/models/
